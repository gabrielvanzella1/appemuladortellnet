<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.logisticapp.emuladortelnet">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EmuladorTelnet"
        android:usesCleartextTraffic="true"
        android:name=".EmuladorTelnetApplication">

        <!-- 1. Licenca (launcher) -->
        <activity
            android:name=".LicenseActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="emuladortelnet" android:host="payment" />
            </intent-filter>
        </activity>

        <!-- 2. Lista de hosts -->
        <activity
            android:name=".HostsActivity"
            android:exported="false" />

        <!-- 3. Configuracao do host -->
        <activity
            android:name=".HostConfigActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 4. Configuracoes avancadas do host -->
        <activity
            android:name=".HostAdvancedActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Opcoes gerais do app -->
        <activity
            android:name=".GeneralOptionsActivity"
            android:exported="false" />

        <!-- Menu de Configuracoes (Comunicacao / Emulacao / Tela) -->
        <activity
            android:name=".ConfigMenuActivity"
            android:exported="false" />

        <!-- Configuracoes > Tela > Opcoes de tela -->
        <activity
            android:name=".ScreenOptionsActivity"
            android:exported="false" />

        <!-- Configuracoes > Tela > Cores da tela -->
        <activity
            android:name=".ScreenColorsActivity"
            android:exported="false" />

        <!-- Configuracoes > Tela > VT Mapeamento de atributos -->
        <activity
            android:name=".VtAttrMapActivity"
            android:exported="false" />

        <!-- Modelos de sessao -->
        <activity
            android:name=".TemplatesActivity"
            android:exported="false" />

        <!-- Configuracoes > Tela > Configuracao da barra de ferramentas -->
        <activity
            android:name=".ToolbarConfigActivity"
            android:exported="false" />
        <activity
            android:name=".ToolbarAddActivity"
            android:exported="false" />

        <!-- Configuracoes > Comunicacao > Telnet Opcoes -->
        <activity
            android:name=".TelnetOptionsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Configuracoes > Comunicacao > Servidor proxy -->
        <activity
            android:name=".ProxyActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Configuracoes > Emulacao > VT Opcoes -->
        <activity
            android:name=".VtOptionsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Configuracoes > Emulacao > Transliteracao -->
        <activity
            android:name=".TransliterationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Configuracoes > Emulacao > Geral -->
        <activity
            android:name=".GeneralEmulationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Configuracoes > Dispositivos > Configuracao de impressao -->
        <activity
            android:name=".PrintConfigActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Configuracoes > Dispositivos > Leitor de codigo de barras -->
        <activity
            android:name=".BarcodeConfigActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 5. Terminal Telnet -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Configuracoes > Teclado > Configurar teclado ScanTE -->
        <activity
            android:name=".KeyboardConfigActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".KeyboardPageEditActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Calculadora flutuante -->
        <service
            android:name=".FloatingCalculatorService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Teclado personalizado ScanTE (IME) -->
        <service
            android:name=".keyboard.TerminalInputMethodService"
            android:label="ScanTE Keyboard"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/input_method" />
        </service>

    </application>

</manifest>
