<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.logisticapp.emuladortelnet">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EmuladorTelnet"
        android:usesCleartextTraffic="true"
        android:name=".EmuladorTelnetApplication">

        <!-- 1. Licenca (launcher) -->
        <activity
            android:name=".LicenseActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="emuladortelnet" android:host="payment" />
            </intent-filter>
        </activity>

        <!-- 2. Lista de hosts -->
        <activity
            android:name=".HostsActivity"
            android:exported="false" />

        <!-- 3. Configuracao do host -->
        <activity
            android:name=".HostConfigActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- 4. Configuracoes avancadas do host -->
        <activity
            android:name=".HostAdvancedActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Opcoes gerais do app -->
        <activity
            android:name=".GeneralOptionsActivity"
            android:exported="false" />

        <!-- Menu de Configuracoes (Comunicacao / Emulacao / Tela) -->
        <activity
            android:name=".ConfigMenuActivity"
            android:exported="false" />

        <!-- Configuracoes > Tela > Opcoes de tela -->
        <activity
            android:name=".ScreenOptionsActivity"
            android:exported="false" />

        <!-- Configuracoes > Tela > Cores da tela -->
        <activity
            android:name=".ScreenColorsActivity"
            android:exported="false" />

        <!-- Configuracoes > Tela > Configuracao da barra de ferramentas -->
        <activity
            android:name=".ToolbarConfigActivity"
            android:exported="false" />
        <activity
            android:name=".ToolbarAddActivity"
            android:exported="false" />

        <!-- 5. Terminal Telnet -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

    </application>

</manifest>
