<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_brand_dark"
    android:padding="16dp">

    <!-- Header com Logo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingVertical="24dp">

        <FrameLayout
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:background="@drawable/circle_logo_dark">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_scante_logo"
                android:contentDescription="ScanTE" />
        </FrameLayout>

        <!-- Nome: Scan (branco) + TE (verde) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan"
                android:textSize="32sp"
                android:textColor="#F8F9FA"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TE"
                android:textSize="32sp"
                android:textColor="@color/brand_green"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Conecta · Sincroniza · Simplifica"
            android:textSize="12sp"
            android:textColor="#8DA2B0"
            android:gravity="center"
            android:letterSpacing="0.04"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Status Card -->
    <LinearLayout
        android:id="@+id/status_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_dark"
        android:padding="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/license_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Teste Gratuito"
            android:textSize="16sp"
            android:textColor="@color/brand_green"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/license_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="30 dias grátis para testar"
            android:textSize="14sp"
            android:textColor="#E0E6EA"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dias Restantes"
                    android:textSize="12sp"
                    android:textColor="#8DA2B0" />

                <TextView
                    android:id="@+id/days_remaining"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="30"
                    android:textSize="20sp"
                    android:textColor="@color/brand_green"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tipo"
                    android:textSize="12sp"
                    android:textColor="#8DA2B0" />

                <TextView
                    android:id="@+id/license_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Trial"
                    android:textSize="20sp"
                    android:textColor="@color/brand_green"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Ativar licença com chave -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_dark"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Já tem uma licença?"
            android:textSize="13sp"
            android:textColor="#8DA2B0"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/input_license_key"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="SCTE-XXXXXX-XXXXXX-XXXXXX"
                android:textColorHint="#4A6070"
                android:textColor="#F8F9FA"
                android:textSize="13sp"
                android:inputType="textCapCharacters|textNoSuggestions"
                android:background="@drawable/input_dark_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_activate_key"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Ativar"
                android:textColor="@color/brand_petrol"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/button_accent_bg"
                android:paddingHorizontal="16dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_activation_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="@color/brand_green"
            android:layout_marginTop="8dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Loading indicator durante criação/verificação de pagamento -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp"
        android:indeterminateTint="@color/brand_green"
        android:visibility="gone" />

    <!-- Botões de Ação -->
    <Button
        android:id="@+id/btn_continue"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Continuar"
        android:textColor="@color/brand_petrol"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/button_accent_bg"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_buy_license"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Comprar Licença"
        android:textColor="@color/brand_green"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/card_dark"
        android:layout_marginBottom="24dp" />

    <!-- Info Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="📌 A licença é vitalícia após o pagamento\n\n💳 Aceita Mercado Pago\n\n✅ 30 dias grátis para testar"
        android:textSize="13sp"
        android:textColor="#8DA2B0"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:padding="16dp" />

    <!-- Device Info (Debug) -->
    <TextView
        android:id="@+id/device_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="10sp"
        android:textColor="#5A6B78"
        android:gravity="center"
        android:layout_marginTop="12dp" />

    <!-- ===== PAINEL DEBUG (oculto em produção) ===== -->
    <LinearLayout
        android:id="@+id/debug_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A2A1A"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛠 DEBUG — Licença"
            android:textSize="11sp"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Linha 1: expirar e resetar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_debug_expire"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Expirar agora"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C62828" />

            <Button
                android:id="@+id/btn_debug_reset"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Reset (7 dias)"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0" />
        </LinearLayout>

        <!-- Linha 2: N dias customizados -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/debug_days_input"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:hint="dias"
                android:textColorHint="#4A6070"
                android:textColor="#F8F9FA"
                android:textSize="13sp"
                android:inputType="number"
                android:background="@drawable/input_dark_bg"
                android:paddingHorizontal="10dp" />

            <Button
                android:id="@+id/btn_debug_set_days"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Definir dias"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2E7D32" />
        </LinearLayout>

        <!-- Linha 3: limpar tudo -->
        <Button
            android:id="@+id/btn_debug_clear"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:text="Limpar tudo (simula 1ª instalação)"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6A1B9A" />

    </LinearLayout>

</LinearLayout>
