<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fl_root"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/brand_petrol"
    android:elevation="12dp">

    <!-- Cabeçalho arrastável -->
    <LinearLayout
        android:id="@+id/fl_header"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/primary_dark"
        android:paddingLeft="12dp"
        android:paddingRight="4dp">

        <TextView
            android:id="@+id/fl_title"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⠿  Calculadora"
            android:textColor="@color/secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingLeft="4dp"/>

        <ImageButton
            android:id="@+id/fl_minimize"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/arrow_down_float"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Minimizar"
            android:tint="@color/brand_white"/>

        <ImageButton
            android:id="@+id/fl_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Fechar"
            android:tint="@color/secondary"/>
    </LinearLayout>

    <!-- Corpo da calculadora (idêntico ao dialog) -->
    <LinearLayout
        android:id="@+id/fl_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/tv_expression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="24dp"
            android:gravity="end|center_vertical"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:textSize="12sp"
            android:textColor="@color/primary_light"
            android:singleLine="true"
            android:ellipsize="start"
            android:text="" />

        <TextView
            android:id="@+id/tv_display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:gravity="end|center_vertical"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:textSize="34sp"
            android:textColor="@color/brand_white"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:ellipsize="start"
            android:text="0" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/primary_light"
            android:layout_marginBottom="4dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/CalcRow">
            <Button android:id="@+id/btn_clear"   style="@style/CalcBtnFunc" android:text="C" />
            <Button android:id="@+id/btn_sign"    style="@style/CalcBtnFunc" android:text="±" />
            <Button android:id="@+id/btn_percent" style="@style/CalcBtnFunc" android:text="%" />
            <Button android:id="@+id/btn_div"     style="@style/CalcBtnOp"   android:text="÷" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/CalcRow">
            <Button android:id="@+id/btn_7"   style="@style/CalcBtnNum" android:text="7" />
            <Button android:id="@+id/btn_8"   style="@style/CalcBtnNum" android:text="8" />
            <Button android:id="@+id/btn_9"   style="@style/CalcBtnNum" android:text="9" />
            <Button android:id="@+id/btn_mul" style="@style/CalcBtnOp"  android:text="×" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/CalcRow">
            <Button android:id="@+id/btn_4"   style="@style/CalcBtnNum" android:text="4" />
            <Button android:id="@+id/btn_5"   style="@style/CalcBtnNum" android:text="5" />
            <Button android:id="@+id/btn_6"   style="@style/CalcBtnNum" android:text="6" />
            <Button android:id="@+id/btn_sub" style="@style/CalcBtnOp"  android:text="-" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/CalcRow">
            <Button android:id="@+id/btn_1"    style="@style/CalcBtnNum" android:text="1" />
            <Button android:id="@+id/btn_2"    style="@style/CalcBtnNum" android:text="2" />
            <Button android:id="@+id/btn_3"    style="@style/CalcBtnNum" android:text="3" />
            <Button android:id="@+id/btn_add"  style="@style/CalcBtnOp"  android:text="+" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/CalcRow">
            <Button android:id="@+id/btn_0"   style="@style/CalcBtnNum"
                android:layout_width="0dp" android:layout_weight="2"
                android:text="0" android:gravity="center_vertical|start" android:paddingLeft="22dp"/>
            <Button android:id="@+id/btn_dot"    style="@style/CalcBtnNum" android:text="." />
            <Button android:id="@+id/btn_equals" style="@style/CalcBtnEq"  android:text="=" />
        </LinearLayout>
        <!-- Botão enviar ao terminal (visível só no terminal) -->
        <Button
            android:id="@+id/btn_send_terminal"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="4dp"
            android:text="→ Enviar ao terminal"
            android:textSize="13sp"
            android:backgroundTint="@color/secondary"
            android:textColor="@color/brand_petrol"
            android:visibility="gone"/>
    </LinearLayout>

</LinearLayout>
