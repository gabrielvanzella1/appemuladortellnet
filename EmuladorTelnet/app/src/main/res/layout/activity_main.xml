<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- AppBar -->
    <LinearLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:elevation="8dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <ImageButton
            android:id="@+id/keyboardToggle"
            android:layout_width="40dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_keyboard"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Mostrar/ocultar teclado"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/disconnectButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Desconectar"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:background="@color/primary_dark"
            android:enabled="false"
            android:paddingStart="10dp"
            android:paddingEnd="10dp" />
    </LinearLayout>

    <!-- Terminal Output -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"
        android:fillViewport="true">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <TextView
                android:id="@+id/terminalOutput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:padding="6dp"
                android:background="#000000"
                android:textColor="#00FF00"
                android:includeFontPadding="false"
                android:lineSpacingExtra="0dp"
                android:textIsSelectable="true" />
        </HorizontalScrollView>
    </ScrollView>

    <!-- Command Input -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#000000">

        <EditText
            android:id="@+id/commandInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="@string/hint_command"
            android:inputType="text"
            android:padding="6dp"
            android:background="#1a1a1a"
            android:textColor="#00FF00"
            android:textColorHint="#666666"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:imeOptions="actionSend"
            android:enabled="false" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/button_send"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:background="@color/primary"
            android:layout_marginStart="4dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:enabled="false" />
    </LinearLayout>

    <!-- Barras de ferramentas (4 linhas geradas dinamicamente) -->
    <LinearLayout
        android:id="@+id/controlKeysBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#000000"
        android:padding="2dp"
        android:visibility="gone" />

</LinearLayout>
