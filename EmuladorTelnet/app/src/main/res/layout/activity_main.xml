<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_activity_main"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Connection Status -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_disconnected"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <!-- Host Input -->
    <EditText
        android:id="@+id/hostInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_host"
        android:inputType="text"
        android:layout_marginBottom="8dp" />

    <!-- Port Input -->
    <EditText
        android:id="@+id/portInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_port"
        android:inputType="number"
        android:layout_marginBottom="16dp" />

    <!-- Saved Connections Spinner -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Spinner
            android:id="@+id/savedConnectionsSpinner"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:prompt="@string/spinner_saved_connections" />

        <Button
            android:id="@+id/saveConnectionButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/button_save_connection"
            android:textSize="10sp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Connect Button -->
    <Button
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/button_connect"
        android:layout_marginBottom="8dp" />

    <!-- Disconnect Button -->
    <Button
        android:id="@+id/disconnectButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/button_disconnect"
        android:enabled="false"
        android:layout_marginBottom="16dp" />

    <!-- Terminal Output -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/terminalOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:background="#000000"
            android:textColor="#00FF00" />
    </ScrollView>

    <!-- Command Input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <EditText
            android:id="@+id/commandInput"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Digitar comando..."
            android:inputType="text"
            android:padding="8dp"
            android:background="#1a1a1a"
            android:textColor="#00FF00"
            android:textColorHint="#666666"
            android:fontFamily="monospace"
            android:imeOptions="actionSend"
            android:enabled="false" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="ENVIAR"
            android:layout_marginStart="8dp"
            android:enabled="false" />
    </LinearLayout>

</LinearLayout>
