<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="Servidor proxy"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_arrow_back" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ===== CONEXÃO AO PROXY ===== -->
            <TextView style="@style/TnSection" android:text="Servidor proxy" />

            <LinearLayout android:id="@+id/row_use_server" style="@style/TnRow">
                <TextView style="@style/TnLabel" android:text="Usar servidor proxy" />
                <CheckBox android:id="@+id/ck_use_server" style="@style/TnCheck" />
            </LinearLayout>
            <View style="@style/TnDivider" />

            <LinearLayout style="@style/TnRow">
                <TextView style="@style/TnLabel" android:text="Endereço (IP ou hostname)" />
                <EditText android:id="@+id/in_address" style="@style/TnInput"
                    android:inputType="textUri"
                    android:hint="192.168.1.100" />
            </LinearLayout>
            <View style="@style/TnDivider" />

            <LinearLayout style="@style/TnRow">
                <TextView style="@style/TnLabel" android:text="Porta" />
                <EditText android:id="@+id/in_port" style="@style/TnInput"
                    android:inputType="number"
                    android:hint="3128" />
            </LinearLayout>
            <View style="@style/TnDivider" />

            <LinearLayout android:id="@+id/row_secure" style="@style/TnRow">
                <TextView style="@style/TnLabel" android:text="Comunicação segura (HTTPS CONNECT)" />
                <CheckBox android:id="@+id/ck_secure" style="@style/TnCheck" />
            </LinearLayout>

            <!-- ===== AUTENTICAÇÃO ===== -->
            <TextView style="@style/TnSection" android:text="Autenticação (opcional)" />

            <LinearLayout style="@style/TnRow">
                <TextView style="@style/TnLabel" android:text="Usuário" />
                <EditText android:id="@+id/in_username" style="@style/TnInput"
                    android:inputType="text"
                    android:hint="deixe vazio se não exigido" />
            </LinearLayout>
            <View style="@style/TnDivider" />

            <LinearLayout style="@style/TnRow">
                <TextView style="@style/TnLabel" android:text="Senha" />
                <EditText android:id="@+id/in_password" style="@style/TnInput"
                    android:inputType="textPassword"
                    android:hint="••••••" />
            </LinearLayout>

            <!-- ===== MANTER CONEXAO ===== -->
            <TextView style="@style/TnSection"
                android:text="Proxy mantém conexão com o host (segundos)" />

            <LinearLayout style="@style/TnRow">
                <TextView style="@style/TnLabel" android:text="Ao desconectar manualmente" />
                <EditText android:id="@+id/in_keep_user" style="@style/TnInput"
                    android:inputType="number"
                    android:hint="0" />
            </LinearLayout>
            <View style="@style/TnDivider" />

            <LinearLayout style="@style/TnRow">
                <TextView style="@style/TnLabel" android:text="Se conexão cair" />
                <EditText android:id="@+id/in_keep_lost" style="@style/TnInput"
                    android:inputType="number"
                    android:hint="300" />
            </LinearLayout>

            <!-- ===== TESTE ===== -->
            <TextView style="@style/TnSection" android:text="Diagnóstico" />

            <LinearLayout android:id="@+id/row_test_proxy" style="@style/TnRow">
                <TextView style="@style/TnLabel" android:text="Testar conexão ao proxy" />
                <ImageView style="@style/ConfigChevron" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
