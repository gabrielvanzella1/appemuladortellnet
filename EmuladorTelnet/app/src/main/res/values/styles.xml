<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme - AppCompat with Auticode Branding -->
    <style name="Theme.EmuladorTelnet" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Auticode Brand Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/secondary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Linha de opcao (label + switch) -->
    <style name="OptionRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="OptionLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:paddingEnd">12dp</item>
    </style>

    <style name="OptionSwitch">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:thumbTint">@color/primary</item>
        <item name="android:trackTint">@color/primary_light</item>
    </style>

    <style name="OptionDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#22000000</item>
        <item name="android:layout_marginTop">12dp</item>
    </style>

    <!-- Menu de configuracoes (lista agrupada) -->
    <style name="ConfigSection">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="ConfigItemRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="ConfigItemText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="ConfigChevron">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:src">@drawable/ic_chevron_right</item>
        <item name="android:contentDescription">@null</item>
    </style>

    <style name="ConfigItemValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:gravity">end</item>
        <item name="android:maxWidth">160dp</item>
    </style>

    <style name="ConfigItemDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#1A000000</item>
        <item name="android:layout_marginStart">16dp</item>
    </style>

    <style name="ConfigSwatch">
        <item name="android:layout_width">52dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_marginEnd">8dp</item>
    </style>

    <!-- Linha de Telnet Opcoes: label a esquerda + campo/controle a direita -->
    <style name="TnRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="TnLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:paddingEnd">10dp</item>
    </style>

    <style name="TnInput">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/tn_input_bg</item>
        <item name="android:padding">8dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">#999999</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:gravity">top|start</item>
    </style>

    <style name="TnCheck">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:clickable">false</item>
        <item name="android:focusable">false</item>
        <item name="android:buttonTint">@color/primary</item>
    </style>

    <style name="TnSection">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingTop">22dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="TnValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:gravity">end</item>
        <item name="android:maxWidth">150dp</item>
    </style>

    <!-- Calculadora (cores ScanTE) -->
    <style name="CalcRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="CalcBtnBase">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">58dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/brand_white</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Números: azul petróleo médio -->
    <style name="CalcBtnNum" parent="CalcBtnBase">
        <item name="android:backgroundTint">@color/primary_light</item>
    </style>

    <!-- Operadores: verde jade -->
    <style name="CalcBtnOp" parent="CalcBtnBase">
        <item name="android:backgroundTint">@color/secondary</item>
        <item name="android:textColor">@color/brand_petrol</item>
    </style>

    <!-- Funções (C ± %): azul petróleo mais escuro -->
    <style name="CalcBtnFunc" parent="CalcBtnBase">
        <item name="android:backgroundTint">@color/primary_dark</item>
        <item name="android:textColor">@color/secondary</item>
    </style>

    <!-- Igual: verde jade -->
    <style name="CalcBtnEq" parent="CalcBtnBase">
        <item name="android:backgroundTint">@color/secondary</item>
        <item name="android:textColor">@color/brand_petrol</item>
    </style>

    <style name="TnDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#1A000000</item>
        <item name="android:layout_marginStart">16dp</item>
    </style>
</resources>
